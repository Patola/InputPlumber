# Maintainer: Cláudio 'Patola' Sampaio <patola@gmail.com>
pkgname=inputplumber-patola
_pkgbase=inputplumber
pkgver=0.77.7
pkgrel=1
pkgdesc="Open source input router and remapper daemon for Linux (Patola fork with Legion Go 2 fixes)"
arch=('x86_64')
url="https://github.com/Patola/InputPlumber"
license=('GPL-3.0-or-later')
depends=('dbus' 'hidapi' 'libevdev' 'libiio')
makedepends=('rust' 'cargo' 'clang' 'git' 'linux-headers')
optdepends=('polkit: for policy-based authentication')
provides=('inputplumber')
conflicts=('inputplumber' 'inputplumber-bin' 'inputplumber-git')
source=("$_pkgbase::git+https://github.com/Patola/InputPlumber.git#branch=main")
sha256sums=('SKIP')

pkgver() {
  cd "$_pkgbase"
  local _cargover
  _cargover=$(grep '^version =' Cargo.toml | head -1 | cut -d'"' -f2)
  printf "%s.r%s.g%s" "$_cargover" "$(git rev-list --count HEAD)" "$(git rev-parse --short HEAD)"
}

build() {
  cd "$_pkgbase"
  export RUSTUP_TOOLCHAIN=stable
  # Force hidapi-hidraw linkage: the hidapi 2.x crate's build script may not
  # emit the link arg when the system library is found via pkg-config on Arch.
  export RUSTFLAGS="-C link-arg=-lhidapi-hidraw"
  cargo build --release --locked
}

package() {
  cd "$_pkgbase"
  install -D -m 755 target/release/inputplumber \
    "$pkgdir/usr/bin/inputplumber"
  install -D -m 644 "rootfs/usr/share/dbus-1/system.d/org.shadowblip.InputPlumber.conf" \
    "$pkgdir/usr/share/dbus-1/system.d/org.shadowblip.InputPlumber.conf"
  install -D -m 644 -t "$pkgdir/usr/share/polkit-1/actions/" \
    rootfs/usr/share/polkit-1/actions/*
  install -D -m 644 -t "$pkgdir/usr/share/polkit-1/rules.d/" \
    rootfs/usr/share/polkit-1/rules.d/*
  install -D -m 644 -t "$pkgdir/usr/lib/systemd/system/" \
    rootfs/usr/lib/systemd/system/*
  install -D -m 644 -t "$pkgdir/usr/lib/udev/hwdb.d/" \
    rootfs/usr/lib/udev/hwdb.d/*
  install -D -m 644 -t "$pkgdir/usr/lib/udev/rules.d/" \
    rootfs/usr/lib/udev/rules.d/*
  install -D -m 644 -t "$pkgdir/usr/share/inputplumber/devices/" \
    rootfs/usr/share/inputplumber/devices/*
  install -D -m 644 -t "$pkgdir/usr/share/inputplumber/schema/" \
    rootfs/usr/share/inputplumber/schema/*
  install -D -m 644 -t "$pkgdir/usr/share/inputplumber/capability_maps/" \
    rootfs/usr/share/inputplumber/capability_maps/*
  install -D -m 644 -t "$pkgdir/usr/share/inputplumber/profiles/" \
    rootfs/usr/share/inputplumber/profiles/*
}

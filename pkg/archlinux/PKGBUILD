# Maintainer: Cláudio 'Patola' Sampaio <patola@gmail.com>
pkgname=inputplumber-patola
_pkgbase=inputplumber
pkgver=0.77.7
pkgrel=1
pkgdesc="Open source input router and remapper daemon for Linux (Patola fork with Legion Go 2 fixes)"
arch=('x86_64')
url="https://github.com/Patola/InputPlumber"
license=('GPL-3.0-or-later')
depends=('dbus' 'hidapi' 'libevdev' 'libiio')
makedepends=('rust' 'cargo' 'git' 'clang')
optdepends=('polkit: for policy-based authentication')
provides=('inputplumber')
conflicts=('inputplumber' 'inputplumber-bin' 'inputplumber-git')
source=("$_pkgbase::git+https://github.com/Patola/InputPlumber.git#branch=main")
sha256sums=('SKIP')

pkgver() {
  cd "$_pkgbase"
  local _cargover
  _cargover=$(grep '^version =' Cargo.toml | head -1 | cut -d'"' -f2)
  printf "%s.r%s.g%s" "$_cargover" "$(git rev-list --count HEAD)" "$(git rev-parse --short HEAD)"
}

build() {
  cd "$_pkgbase"
  export RUSTUP_TOOLCHAIN=stable
  export CARGO_TARGET_DIR=target
  cargo build --release --locked --target x86_64-unknown-linux-gnu
}

package() {
  cd "$_pkgbase"
  make install PREFIX="$pkgdir/usr" BUILD_TYPE=release
}
